{%- comment -%}
  Snippet: sticky-bottom-bar
  Barra fixa inferior que fica por cima de todo o conteúdo
{%- endcomment -%}

<div id="sticky-bottom-bar" role="region" aria-label="Ações rápidas">
  <div class="sbb__inner">
    <button class="sbb__btn" data-action="add-to-cart">
      DODAJ U KOŠARICU
    </button>
  </div>
</div>

<style>
  :root{
    /* altura base da barra (ajuste se quiser) */
    --sbb-h: 54px;
  }

  /* container fixo, por cima de tudo */
  #sticky-bottom-bar{
    position: fixed;
    inset: auto 0 0 0;            /* bottom:0; left:0; right:0 */
    height: var(--sbb-h);
    background: #000000;
    box-shadow: 0 -6px 30px rgba(0,0,0,.08);
    z-index: 2147483000;          /* MUITO alto para sobrepor tudo do Impulse */
    padding-bottom: env(safe-area-inset-bottom); /* iPhones com notch */
    display: block;
  }
  .sbb__inner{
    max-width: var(--page-width, 1400px);
    margin: 0 auto;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
  }
  .sbb__btn{
    width: 100%;
    height: 44px;
    border: 0;
    border-radius: 6px;
    font-weight: 600;
    font-size: 16px;
    cursor: pointer;
  }

  /* opcional: mostrar só no mobile */
  @media (min-width: 990px){
    #sticky-bottom-bar{ display: none; }
  }

  /* garante que nada do tema passe por cima por engano */
  .header, .announcement-bar, .drawer, .modal, .quick-shop, .search-modal,
  .cart-drawer, .predictive-search{ z-index: auto; }
</style>

<script>
  (function(){
    // evita que o conteúdo fique escondido atrás da barra
    var bar = document.getElementById('sticky-bottom-bar');
    function padBottom(){
      var h = bar.getBoundingClientRect().height || 64;
      document.documentElement.style.setProperty('--sbb-h', h + 'px');
      document.body.style.paddingBottom = h + 'px';
    }
    padBottom();
    window.addEventListener('resize', padBottom);

    // ligar no botão de add-to-cart se desejar (produto atual)
    document.querySelector('#sticky-bottom-bar [data-action="add-to-cart"]')
      ?.addEventListener('click', function(){
        // acione o botão nativo do produto (Impulse usa [type="submit"][name="add"])
        var nativeBtn = document.querySelector('product-form [type="submit"][name="add"], form[action*="/cart/add"] [type="submit"]');
        if(nativeBtn){ nativeBtn.click(); }
      });
  })();
</script>
