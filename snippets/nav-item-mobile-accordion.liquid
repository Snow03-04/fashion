{%- liquid
  assign has_children = false
  if link.links != blank and link.links.size > 0
    assign has_children = true
  endif

  assign title = link.title | escape
-%}

<div class="mm-item">
  {%- if has_children -%}
    <details class="mm-details">
      <summary class="mm-summary">
        <span class="mm-title">{{ title }}</span>
        <span class="mm-caret" aria-hidden="true"></span>
      </summary>

      <div class="mm-panel">
        <div class="mm-children">
          {%- for child in link.links -%}
            {%- liquid
              assign child_has_children = false
              if child.links != blank and child.links.size > 0
                assign child_has_children = true
              endif
            -%}

            {%- if child_has_children -%}
              <div class="mm-child">
                <details class="mm-details mm-details--nested">
                  <summary class="mm-summary mm-summary--nested">
                    <span class="mm-title">{{ child.title | escape }}</span>
                    <span class="mm-caret" aria-hidden="true"></span>
                  </summary>

                  <div class="mm-panel mm-panel--nested">
                    <div class="mm-children mm-children--nested">
                      {%- for grandchild in child.links -%}
                        <a class="mm-link mm-link--grandchild" href="{{ grandchild.url }}">
                          {{ grandchild.title | escape }}
                        </a>
                      {%- endfor -%}
                    </div>
                  </div>
                </details>
              </div>
            {%- else -%}
              <a class="mm-link mm-link--child" href="{{ child.url }}">
                {{ child.title | escape }}
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </details>
  {%- else -%}
    {%- if link.url == blank or link.url == '#' -%}
      <div class="mm-row">
        <span class="mm-title">{{ title }}</span>
      </div>
    {%- else -%}
      <a class="mm-row" href="{{ link.url }}">
        <span class="mm-title">{{ title }}</span>
      </a>
    {%- endif -%}
  {%- endif -%}
</div>