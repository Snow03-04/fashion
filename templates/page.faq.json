        "question_i8zfpF": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "Kako mogu pratiti svoju narudžbu?",
            "content": "<p>Kako biste pratili svoju narudžbu, možete kliknuti na poveznicu za praćenje u e-mailu s potvrdom slanja koji ste primili.</p><p>Ako ne pronađete e-mail s potvrdom u pristigloj pošti, najvjerojatnije se nalazi u mapi neželjene pošte.</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
