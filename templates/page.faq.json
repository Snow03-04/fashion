        },
        "question_8z3EHq": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "U kojem roku mogu vratiti artikl?",
            "content": "<p>U možete vratiti naručene artikle u roku od 30 dana od primitka svoje narudžbe.</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        },
        "question_BNDz6X": {
          "type": "question",
          "settings": {
            "default_open": false,
            "title": "Kako ću primiti povrat novca?",
            "content": "<p>Povrat će se uvijek izvršiti korištenjem načina plaćanja koji ste odabrali. Ako plaćate kreditnom karticom, iznos za vraćene artikle vratit ćemo izravno na račun vaše kreditne kartice. Ako plaćate putem PayPala, iznos će biti uplaćen na vaš PayPal račun.</p>",
            "show_icon": false,
            "icon_name": "icon-award",
            "icon_size": 20,
            "icon_color": ""
          }
        }
      },
