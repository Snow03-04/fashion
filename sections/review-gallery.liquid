{%- comment -%}
  Carrossel de recenzí zákaznic (UGC) — fotky s taškou Aurellis Viktorie.
  Fotky: assets/review-1.jpg ... review-9.jpg
  Jedna řada s šipkami a tečkami pro navigaci.
{%- endcomment -%}

{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign cols = section.settings.columns

  assign r_texts = 'Taška dorazila krásně zabalená a vypadá ještě lépe než na fotkách. Kvalita předčila moje očekávání!|Miluji svou novou kabelku od Aurellis Viktorie. Dostávám samé komplimenty!|Rychlé doručení a perfektní zpracování. Určitě si objednám znovu.|Materiál působí luxusně a balení velmi prémiově. Naprostá spokojenost.|Skvělý poměr ceny a kvality. Vřele doporučuji všem kamarádkám.|Naživo je to ještě hezčí. S touto kabelkou se cítím elegantně každý den.|Objednávka přišla dřív, než jsem čekala. Podpora byla milá a ochotná.|Konečně značka, která spojuje styl a kvalitu. Jsem nadšená!|Krásný dárek pro sebe i pro maminku. Elegantní a praktické.' | split: '|'

  assign r_names = 'Eliška N.|Tereza S.|Kateřina D.|Barbora Č.|Markéta P.|Veronika K.|Lucie V.|Adéla M.|Klára H.' | split: '|'

  assign r_cities = 'Praha|Brno|Ostrava|Plzeň|Liberec|Olomouc|Hradec Králové|České Budějovice|Zlín' | split: '|'
-%}

<style>
  #shopify-section-{{ section.id }} .av-reviews { width: 100%; box-sizing: border-box; }
  #shopify-section-{{ section.id }} .av-reviews__inner { max-width: 1240px; margin: 0 auto; padding: 0 16px; }
  #shopify-section-{{ section.id }} .av-reviews__head { text-align: center; margin-bottom: 28px; }
  #shopify-section-{{ section.id }} .av-reviews__heading { font-size: clamp(24px, 3.5vw, 34px); font-weight: 700; margin: 0 0 8px; line-height: 1.2; }
  #shopify-section-{{ section.id }} .av-reviews__sub { margin: 0; color: #6b6b6b; font-size: 15px; }

  #shopify-section-{{ section.id }} .av-reviews__carousel { position: relative; }
  #shopify-section-{{ section.id }} .av-reviews__track { --av-per-view: {{ cols }}; --av-gap: 24px; position: relative; display: flex; gap: var(--av-gap); overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth; -ms-overflow-style: none; scrollbar-width: none; padding-bottom: 4px; }
  #shopify-section-{{ section.id }} .av-reviews__track::-webkit-scrollbar { display: none; }
  #shopify-section-{{ section.id }} .av-reviews__card { flex: 0 0 calc((100% - (var(--av-per-view) - 1) * var(--av-gap)) / var(--av-per-view)); scroll-snap-align: start; display: flex; flex-direction: column; background: #fff; border: 1px solid #ececec; border-radius: 18px; overflow: hidden; box-shadow: 0 8px 24px rgba(0,0,0,.06); }
  #shopify-section-{{ section.id }} .av-reviews__media { position: relative; aspect-ratio: 1 / 1; background: #f1f0ee; overflow: hidden; }
  #shopify-section-{{ section.id }} .av-reviews__media::after { content: ""; position: absolute; top: 50%; left: 50%; width: 34px; height: 34px; margin: -17px 0 0 -17px; border-radius: 50%; border: 3px solid rgba(0,0,0,.14); border-top-color: #1a1a1a; animation: av-spin .8s linear infinite; z-index: 1; }
  #shopify-section-{{ section.id }} .av-reviews__media.is-loaded::after { display: none; }
  #shopify-section-{{ section.id }} .av-reviews__media img { position: relative; z-index: 2; width: 100%; height: 100%; object-fit: cover; display: block; opacity: 0; transition: opacity .4s ease; }
  #shopify-section-{{ section.id }} .av-reviews__media.is-loaded img { opacity: 1; }
  @keyframes av-spin { to { transform: rotate(360deg); } }
  #shopify-section-{{ section.id }} .av-reviews__badge { position: absolute; top: 12px; left: 12px; background: rgba(255,255,255,.92); border-radius: 999px; padding: 5px 10px; font-size: 11px; font-weight: 600; color: #1a1a1a; display: inline-flex; align-items: center; gap: 5px; box-shadow: 0 2px 6px rgba(0,0,0,.08); z-index: 3; }
  #shopify-section-{{ section.id }} .av-reviews__body { padding: 16px 18px 20px; display: flex; flex-direction: column; gap: 9px; flex: 1 1 auto; }
  #shopify-section-{{ section.id }} .av-reviews__stars { color: #f5a623; font-size: 17px; letter-spacing: 2px; line-height: 1; }
  #shopify-section-{{ section.id }} .av-reviews__text { margin: 0; font-size: 15px; line-height: 1.55; color: #222; flex: 1 1 auto; }
  #shopify-section-{{ section.id }} .av-reviews__author { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-top: 2px; }
  #shopify-section-{{ section.id }} .av-reviews__name { font-weight: 600; font-size: 14px; color: #111; }
  #shopify-section-{{ section.id }} .av-reviews__city { font-size: 12px; color: #8a8a8a; }

  #shopify-section-{{ section.id }} .av-reviews__arrow { position: absolute; top: 50%; transform: translateY(-50%); z-index: 3; width: 44px; height: 44px; border-radius: 50%; border: 1px solid #e2e2e2; background: #fff; color: #1a1a1a; cursor: pointer; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 14px rgba(0,0,0,.12); transition: background .2s ease, opacity .2s ease, transform .2s ease; }
  #shopify-section-{{ section.id }} .av-reviews__arrow:hover { background: #1a1a1a; color: #fff; }
  #shopify-section-{{ section.id }} .av-reviews__arrow:disabled { opacity: .3; cursor: default; pointer-events: none; }
  #shopify-section-{{ section.id }} .av-reviews__arrow--prev { left: -14px; }
  #shopify-section-{{ section.id }} .av-reviews__arrow--next { right: -14px; }
  #shopify-section-{{ section.id }} .av-reviews__arrow svg { width: 18px; height: 18px; }

  #shopify-section-{{ section.id }} .av-reviews__dots { display: flex; justify-content: center; align-items: center; gap: 9px; margin-top: 24px; min-height: 14px; }
  #shopify-section-{{ section.id }} .av-reviews__dot { width: 11px !important; height: 11px !important; padding: 0 !important; border: 0 !important; border-radius: 999px !important; background: #9a9a9a !important; cursor: pointer; appearance: none !important; -webkit-appearance: none !important; box-shadow: none !important; flex: 0 0 auto; transition: background .2s ease, width .2s ease; }
  #shopify-section-{{ section.id }} .av-reviews__dot:hover { background: #5e5e5e !important; }
  #shopify-section-{{ section.id }} .av-reviews__dot.is-active { background: #111111 !important; width: 28px !important; }

  @media (max-width: 990px) { #shopify-section-{{ section.id }} .av-reviews__track { --av-per-view: 2; } }
  @media (max-width: 600px) {
    #shopify-section-{{ section.id }} .av-reviews__track { --av-per-view: 1.15; }
    #shopify-section-{{ section.id }} .av-reviews__arrow { display: none; }
  }
</style>

<div class="av-reviews" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background: {{ section.settings.bg_color }};">
  <div class="av-reviews__inner">
    {%- if heading != blank or subheading != blank -%}
      <div class="av-reviews__head">
        {%- if heading != blank -%}<h2 class="av-reviews__heading">{{ heading }}</h2>{%- endif -%}
        {%- if subheading != blank -%}<p class="av-reviews__sub">{{ subheading }}</p>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="av-reviews__carousel">
      <button type="button" class="av-reviews__arrow av-reviews__arrow--prev" data-av-prev aria-label="Předchozí">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M15 5l-7 7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
      </button>

      <div class="av-reviews__track" data-av-track>
        {%- for i in (1..9) -%}
          {%- assign idx = forloop.index0 -%}
          {%- assign img = 'review-' | append: forloop.index | append: '.jpg' | asset_url -%}
          <figure class="av-reviews__card">
            <div class="av-reviews__media">
              <span class="av-reviews__badge">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="12" cy="12" r="11" fill="#2e7d32"></circle><path d="M7 12.5l3 3 7-7" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                Ověřený nákup
              </span>
              <img src="{{ img }}" alt="Spokojená zákaznice {{ r_names[idx] }}" loading="lazy" width="800" height="800">
            </div>
            <figcaption class="av-reviews__body">
              <div class="av-reviews__stars" aria-label="Hodnocení 5 z 5">★★★★★</div>
              <p class="av-reviews__text">{{ r_texts[idx] }}</p>
              <div class="av-reviews__author">
                <span class="av-reviews__name">{{ r_names[idx] }}</span>
                <span class="av-reviews__city">{{ r_cities[idx] }}</span>
              </div>
            </figcaption>
          </figure>
        {%- endfor -%}
      </div>

      <button type="button" class="av-reviews__arrow av-reviews__arrow--next" data-av-next aria-label="Další">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
      </button>
    </div>

    <div class="av-reviews__dots" data-av-dots></div>
  </div>
</div>

<script>
  (function () {
    var SECTION_ID = '{{ section.id }}';

    function init() {
      var root = document.getElementById('shopify-section-' + SECTION_ID);
      if (!root) return;
      var track = root.querySelector('[data-av-track]');
      if (!track) return;
      var prev = root.querySelector('[data-av-prev]');
      var next = root.querySelector('[data-av-next]');
      var dotsWrap = root.querySelector('[data-av-dots]');
      var cards = Array.prototype.slice.call(track.children);
      if (!cards.length) return;

      // Spinner: marca cada foto como carregada (remove o loading)
      Array.prototype.slice.call(root.querySelectorAll('.av-reviews__media img')).forEach(function (img) {
        var media = img.parentNode;
        function done() { if (media) media.classList.add('is-loaded'); }
        if (img.complete && img.naturalWidth > 0) { done(); }
        else { img.addEventListener('load', done); img.addEventListener('error', done); }
      });

      function step() { return cards.length > 1 ? Math.max(1, cards[1].offsetLeft - cards[0].offsetLeft) : Math.max(1, cards[0].offsetWidth); }
      function perView() { return Math.max(1, Math.round(track.clientWidth / step())); }
      function pages() { return Math.max(1, Math.ceil(cards.length / perView())); }
      function curPage() { return Math.round(track.scrollLeft / (step() * perView())); }

      function setActiveDot(p) {
        if (!dotsWrap) return;
        Array.prototype.slice.call(dotsWrap.children).forEach(function (d, i) {
          d.classList.toggle('is-active', i === p);
        });
      }

      function goPage(p) {
        var pv = perView();
        p = Math.max(0, Math.min(p, pages() - 1));
        var i = Math.min(p * pv, cards.length - 1);
        setActiveDot(p);
        track.scrollTo({ left: cards[i].offsetLeft - cards[0].offsetLeft, behavior: 'smooth' });
      }

      function buildDots() {
        if (!dotsWrap) return;
        var n = pages();
        dotsWrap.innerHTML = '';
        for (var i = 0; i < n; i++) {
          var b = document.createElement('button');
          b.type = 'button';
          b.className = 'av-reviews__dot';
          b.setAttribute('aria-label', 'Strana ' + (i + 1));
          (function (idx) { b.addEventListener('click', function () { goPage(idx); }); })(i);
          dotsWrap.appendChild(b);
        }
      }

      function update() {
        setActiveDot(curPage());
        if (prev) prev.disabled = track.scrollLeft <= 2;
        if (next) next.disabled = track.scrollLeft >= (track.scrollWidth - track.clientWidth - 2);
      }

      if (prev) prev.onclick = function () { goPage(curPage() - 1); };
      if (next) next.onclick = function () { goPage(curPage() + 1); };

      var st;
      track.onscroll = function () { clearTimeout(st); st = setTimeout(update, 60); };
      var rt;
      window.addEventListener('resize', function () { clearTimeout(rt); rt = setTimeout(function () { buildDots(); update(); }, 150); });

      requestAnimationFrame(function () { buildDots(); update(); });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    document.addEventListener('shopify:section:load', function (e) {
      if (e.detail && e.detail.sectionId === SECTION_ID) init();
    });
  })();
</script>

{% schema %}
{
  "name": "Recenze zákaznic",
  "tag": "section",
  "class": "section-av-reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Nadpis",
      "default": "Co říkají naše zákaznice"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Podnadpis",
      "default": "4,8/5 ★ — více než 13 465 hodnocení"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Viditelných karet (počítač)",
      "default": 3
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Barva pozadí",
      "default": "#faf9f7"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Odsazení nahoře",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Odsazení dole",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Recenze zákaznic"
    }
  ]
}
{% endschema %}
