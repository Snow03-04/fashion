{%- liquid
  assign l_coll = section.settings.left_collection
  assign r_coll = section.settings.right_collection

  assign l_img = section.settings.left_image
  if l_img == blank and l_coll and l_coll.image
    assign l_img = l_coll.image
  endif

  assign r_img = section.settings.right_image
  if r_img == blank and r_coll and r_coll.image
    assign r_img = r_coll.image
  endif

  assign l_url = section.settings.left_link
  if l_url == blank and l_coll
    assign l_url = l_coll.url
  endif

  assign r_url = section.settings.right_link
  if r_url == blank and r_coll
    assign r_url = r_coll.url
  endif
-%}


<section class="twocols">
 <div class="twocols__grid {% if section.settings.stack_on_mobile %}twocols__stack{% endif %}">
  {% for side in (1..2) %}
    {% if side == 1 %}
      {% assign img = l_img %}
      {% assign url = l_url %}
      {% assign heading = section.settings.left_heading %}
      {% assign btn = section.settings.left_button %}
      {% assign side_class = 'left' %}
    {% else %}
      {% assign img = r_img %}
      {% assign url = r_url %}
      {% assign heading = section.settings.right_heading %}
      {% assign btn = section.settings.right_button %}
      {% assign side_class = 'right' %}
    {% endif %}

    <a class="twocols__tile twocols__{{ side_class }}"
       href="{{ url | default: '#' }}"
       aria-label="{{ heading | escape }}">
      <div class="twocols__media ratio-{{ section.settings.aspect_ratio | replace: '/', '-' }}">
       {% if img != blank %}
          {% assign alt_text = img.alt | default: heading %}
          {{ img
            | image_url: width: 2000
            | image_tag:
              loading: 'lazy',
              class: 'twocols__img',
              alt: alt_text,
              sizes: '(max-width: 749px) 100vw, 50vw',
              widths: '550, 750, 1100, 1500, 2000'
          }}
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'twocols__placeholder' }}
        {% endif %}

        <span class="twocols__overlay" style="--overlay: {{ section.settings.overlay_opacity }}%;"></span>
        <div class="twocols__content pos-{{ section.settings.text_align }}">
          <div class="twocols__header">
            <h3 class="twocols__title">{{ heading }}</h3>
            {% if btn != blank %}
              <span class="btn btn--outline {{ section.settings.button_size }}">
                <span>{{ btn | escape }}</span>
              </span>
            {% endif %}
          </div>
        </div>
      </div>
    </a>
  {% endfor %}
</div>

</section>

<style>

  #shopify-section-{{ section.id }} .twocols__content .btn.btn--outline {
    border: 1px solid #fff;   
    color: #fff;              
    background: transparent;  
  }

  #shopify-section-{{ section.id }} .twocols__content .btn.btn--outline:hover {
    background: #fff;         
    color: #000;              
  }

  #shopify-section-{{ section.id }} .twocols__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  #shopify-section-{{ section.id }} .twocols__title {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .twocols__content .btn {
    margin: 0;
  }

  
 
  #shopify-section-{{ section.id }} .twocols__grid{
    display:grid; gap:16px; grid-template-columns:1fr 1fr;
  }
  #shopify-section-{{ section.id }} .twocols__stack{
    
  }
  @media (max-width: 749px){
    #shopify-section-{{ section.id }} .twocols__grid{ grid-template-columns:1fr; }
  }

  #shopify-section-{{ section.id }} .twocols__tile{ display:block; text-decoration:none; overflow:hidden; }
  #shopify-section-{{ section.id }} .twocols__media{ position:relative; width:100%; height:100%; }

 
  #shopify-section-{{ section.id }} .ratio-auto{ aspect-ratio:auto; }
  #shopify-section-{{ section.id }} .ratio-3-2{ aspect-ratio:3/2; }
  #shopify-section-{{ section.id }} .ratio-4-3{ aspect-ratio:4/3; }
  #shopify-section-{{ section.id }} .ratio-16-9{ aspect-ratio:16/9; }
  #shopify-section-{{ section.id }} .ratio-1-1{ aspect-ratio:1/1; }

  #shopify-section-{{ section.id }} .twocols__img{ width:100%; height:100%; object-fit:cover; display:block; }

  #shopify-section-{{ section.id }} .twocols__overlay{
    position:absolute; inset:0; background:rgba(0,0,0, calc(var(--overlay)/100));
    transition:background .2s ease;
  }
  #shopify-section-{{ section.id }} .twocols__tile:hover .twocols__overlay{ background:rgba(0,0,0, calc((var(--overlay)+10)/100)); }

  #shopify-section-{{ section.id }} .twocols__content{
    position:absolute; inset:auto; padding:18px 20px;
    display:flex; flex-direction:column; gap:10px; align-items:flex-start; justify-content:flex-end;
    color:#fff; text-shadow:0 1px 8px rgba(0,0,0,.35);
  }

  #shopify-section-{{ section.id }} .pos-bottom-left{ left:0; right:auto; bottom:0; }
  #shopify-section-{{ section.id }} .pos-bottom-right{ right:0; left:auto; bottom:0; align-items:flex-end; text-align:right; }
  #shopify-section-{{ section.id }} .pos-top-left{ left:0; top:0; }
  #shopify-section-{{ section.id }} .pos-top-right{ right:0; top:0; align-items:flex-end; text-align:right; }
  #shopify-section-{{ section.id }} .pos-center{
    inset:0; margin:auto; width:max-content; height:max-content; text-align:center; align-items:center; justify-content:center;
  }

  #shopify-section-{{ section.id }} .twocols__title{ font-size:clamp(22px, 3.2vw, 36px); font-weight:700; margin:0; }
</style>

{% schema %}
{
  "name": "Two collections",
  "settings": [
    { "type": "collection", "id": "left_collection", "label": "Left collection" },
    { "type": "image_picker", "id": "left_image", "label": "Left override image (optional)" },
    { "type": "text", "id": "left_heading", "label": "Left heading", "default": "Men's" },
    { "type": "text", "id": "left_button", "label": "Left button text", "default": "See all" },
    { "type": "url", "id": "left_link", "label": "Left custom link (optional)" },

    { "type": "collection", "id": "right_collection", "label": "Right collection" },
    { "type": "image_picker", "id": "right_image", "label": "Right override image (optional)" },
    { "type": "text", "id": "right_heading", "label": "Right heading", "default": "Women's" },
    { "type": "text", "id": "right_button", "label": "Right button text", "default": "See all" },
    { "type": "url", "id": "right_link", "label": "Right custom link (optional)" },

    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "default": "3/2",
      "options": [
        { "label": "Auto", "value": "auto" },
        { "label": "3:2", "value": "3/2" },
        { "label": "4:3", "value": "4/3" },
        { "label": "16:9", "value": "16/9" },
        { "label": "Square 1:1", "value": "1/1" }
      ]
    },
    { "type": "checkbox", "id": "stack_on_mobile", "label": "Stack on mobile", "default": true },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay darkness", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 30 },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text position",
      "default": "bottom-left",
      "options": [
        { "label": "Bottom left", "value": "bottom-left" },
        { "label": "Bottom right", "value": "bottom-right" },
        { "label": "Center", "value": "center" },
        { "label": "Top left", "value": "top-left" },
        { "label": "Top right", "value": "top-right" }
      ]
    }
  ],
  "presets": [{ "name": "Two collections side by side" }]
}
{% endschema %}
